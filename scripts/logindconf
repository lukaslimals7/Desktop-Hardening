function f_logindconf {
  echo "[$SCRIPT_COUNT] Systemd/logind.conf (desktop)"

  sed -i 's/^#KillUserProcesses=no/KillUserProcesses=no/' "$LOGINDCONF"
  sed -i 's/^#KillExcludeUsers=root/KillExcludeUsers=root/' "$LOGINDCONF"
  sed -i 's/^#IdleAction=ignore/IdleAction=ignore/' "$LOGINDCONF"
  sed -i 's/^#IdleActionSec=30min/IdleActionSec=30min/' "$LOGINDCONF"
  sed -i 's/^#RemoveIPC=yes/RemoveIPC=yes/' "$LOGINDCONF"

  systemctl daemon-reload

  ((SCRIPT_COUNT++))
}
